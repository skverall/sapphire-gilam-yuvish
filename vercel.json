{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.yuvamiz.uz"
        }
      ],
      "destination": "https://yuvamiz.uz/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.yuvamiz.uz"
        }
      ],
      "destination": "https://yuvamiz.uz/:path*",
      "permanent": true
    },
    {
      "source": "/ru",
      "destination": "/ru/",
      "permanent": true
    },
    {
      "source": "/en",
      "destination": "/en/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/ru/",
      "destination": "/ru/index.html"
    },
    {
      "source": "/en/",
      "destination": "/en/index.html"
    }
  ]
}
